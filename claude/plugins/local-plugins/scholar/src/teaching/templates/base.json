{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Base Template for Teaching Content",
  "description": "Common fields shared across all teaching content types (exam, quiz, lecture, assignment, syllabus)",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Template schema version for compatibility tracking"
    },
    "template_type": {
      "type": "string",
      "enum": ["exam", "quiz", "lecture", "assignment", "syllabus"],
      "description": "Type of teaching content"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Content title (e.g., 'Midterm Exam - ANOVA')"
        },
        "course": {
          "type": "string",
          "source": "config",
          "description": "Course name from .flow/teach-config.yml"
        },
        "course_code": {
          "type": "string",
          "source": "config",
          "description": "Course code (e.g., 'STAT 545')"
        },
        "date": {
          "type": "string",
          "format": "date",
          "default": "auto",
          "description": "ISO 8601 date (auto-filled with today if 'auto')"
        },
        "author": {
          "type": "string",
          "source": "config",
          "description": "Instructor name from config"
        }
      },
      "required": ["title", "date"]
    },
    "generated_by": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string",
          "const": "scholar",
          "auto": true
        },
        "version": {
          "type": "string",
          "auto": true,
          "description": "Scholar version that generated this content"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "auto": true,
          "description": "ISO 8601 timestamp of generation"
        },
        "model": {
          "type": "string",
          "auto": true,
          "description": "AI model used for generation (e.g., 'claude-3-5-sonnet')"
        }
      },
      "required": ["tool", "timestamp"]
    }
  },
  "required": ["schema_version", "template_type", "metadata", "generated_by"]
}
